<Window x:Class="BingoWPF.ResumenBingoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resumen Final"
        Width="1920"
        Height="1080"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Grid Margin="-4">

        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="95"/>
        </Grid.RowDefinitions>

        <TextBlock Text="RESUMEN FINAL DEL BINGO"
                   FontSize="80"
                   FontWeight="Bold"
                   Foreground="Black"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top" Margin="0,-26,0,0"/>

        <Border Grid.Row="1"
                BorderBrush="Black"
                BorderThickness="2"
                CornerRadius="20"
                Padding="25" Margin="32,0,63,0">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <TextBlock x:Name="TxtResumen"
                Margin="60,0,30,0"
                FontSize="30"
                FontWeight="Bold"
                Foreground="White"
                Padding="80,25,25,25"
                TextWrapping="Wrap"
                Background="Black"/>

            </ScrollViewer>

        </Border>

        <Button Grid.Row="2"
                Content="VOLVER AL MENÚ"
                Width="300"
                Height="60"
                FontSize="22"
                FontWeight="Bold"
                Background="#27ae60"
                Foreground="Black"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="BtnVolver_Click"/>

    </Grid>
</Window>