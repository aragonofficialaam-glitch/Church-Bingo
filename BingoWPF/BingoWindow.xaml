<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Class="BingoWPF.BingoWindow"
    Title="Bingo Principal"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    WindowStyle="None"
    Background="Transparent">

    <Grid Width="1920" Height="1080">

        <Grid.Background>
            <ImageBrush ImageSource="/Images/definitivas/fondo.png"
                        Stretch="Fill"/>
        </Grid.Background>

        <!-- ultimos -->

        <Border Margin="40,15,0,0"
            Width="600"
            Height="65"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="Black"
            BorderBrush="White"
            BorderThickness="2"
            CornerRadius="10">

            <TextBlock x:Name="LblUltimos"
               Text="Últimos: -"
               FontSize="30"
               FontWeight="Bold"
               Foreground="White"
               VerticalAlignment="Center"
               Margin="30,0,0,0"/>
        </Border>

        <!-- premio -->
        <Border Margin="1010,15,0,0"
                Width="860"
                Height="65"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="Black"
                BorderBrush="White"
                BorderThickness="2"
                CornerRadius="10">

            <TextBlock x:Name="LblPremio"
                       Text="Premio Carton Lleno:"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="15,0,0,0"/>
        </Border>

        <!-- tablero -->
        <Border Margin="42,120,379,240"
                BorderBrush="Transparent"
                BorderThickness="0"
                Background="Transparent"
                Opacity="1"
                CornerRadius="0">

            <Grid>
                <Grid.Background>
                    <ImageBrush ImageSource="pack://application:,,,/Images/definitivas/tablero.png"
                                Stretch="UniformToFill"/>
                </Grid.Background>

                <Grid x:Name="GridTablero"
                      Background="Transparent" Margin="0,0,0,-10"/>
            </Grid>
        </Border>

        <!-- jugadas -->
        <Border Margin="1560,120,12,240"
                BorderBrush="Transparent"
                BorderThickness="7"
                CornerRadius="10">

            <Border.Background>
                <ImageBrush ImageSource="/Images/bingoP/bp/JUGADAS.png"

                            Stretch="Fill"/>
            </Border.Background>

            <DockPanel Margin="10">
                <!-- AQUI -->
                <TextBlock Text="JUGADAS" 
                           DockPanel.Dock="Top"
                           FontSize="48"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="1,-17,0,-8"/>

                <ListBox x:Name="LstJugadas"
                         FontSize="30"
                         FontWeight="Bold"
                         Foreground="White"
                         Background="Transparent"
                         BorderBrush="Transparent" 
                         SelectionChanged="LstJugadas_SelectionChanged"
                         Margin="1,4,0,-8"/>
            </DockPanel>
        </Border>
        <Button Content="Cancelar Bingo"
                    FontSize="24"
                    FontWeight="Bold"
                    Background="Red"
                    BorderThickness="1"
                    BorderBrush="White"
                    Foreground="White"
                    Margin="732,10,986,1000"
                    Click="BtnCancelar_Click"/>

        <!-- numero grande -->
        <!-- numero grande -->
        <Border Width="481"
        Height="225"
        HorizontalAlignment="Left"
        VerticalAlignment="Bottom"
        Margin="624,0,0,10"
        BorderBrush="Black"
        BorderThickness="6"
        CornerRadius="10">

            <Border.Background>
                <ImageBrush ImageSource="/Images/definitivas/numero.png"
                    Stretch="Fill"
                    Opacity="1"/>
            </Border.Background>

            <TextBox x:Name="TxtNumeroGrande"
             FontSize="290"
             FontWeight="Bold"
             Foreground="White"
             Background="Transparent"
             BorderThickness="0"
             Padding="-0,-105,0,0"
             HorizontalContentAlignment="Center"
             VerticalContentAlignment="Center"
             PreviewKeyDown="TxtNumeroGrande_PreviewKeyDown"
             TextChanged="TxtNumeroGrande_TextChanged"
             Margin="0"/>
        </Border>

        <!-- botones -->
        <!-- Botón Revisión -->
        <Button Content="Revisión"
                Width="294"
                Height="68"
                FontSize="24"
                FontWeight="Bold"
                Background="#8e44ad"
                BorderThickness="0"
                BorderBrush="Transparent"
                Foreground="White"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="1220,100,0,156"
                Click="BtnRevision_Click"/>

        <!-- Botón Deshacer -->
        <Button Content="Deshacer"
                Width="294"
                Height="68"
                FontSize="24"
                FontWeight="Bold"
                Background="#e67e22"
                BorderThickness="0"
                BorderBrush="Transparent"
                Foreground="White"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="1220,100,0,85"
                Click="BtnDeshacer_Click"/>

        <!-- Botón Bingo -->
        <Button Content="Bingo"
                Width="294"
                Height="68"
                FontSize="24"
                FontWeight="Bold"
                Background="#27ae60"
                BorderThickness="0"
                BorderBrush="Transparent"
                Foreground="White"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="1220,100,0,14"
                Click="BtnBingo_Click"/>

        <!-- Botón Historial -->
        <Button Content="Historial"
            Width="294"
            Height="48"
            FontSize="24"
            FontWeight="Bold"
            Background="Black"
            BorderThickness="0"
            BorderBrush="Transparent"
            Foreground="White"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Margin="1590,92,0,250"
            Click="BtnHistorial_Click"/>

    </Grid>
</Window>