<Window x:Class="BingoWPF.PreStartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración de Bingo"
        Width="700"
        Height="1080"
        WindowStartupLocation="CenterScreen"
        Background="#121212">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="25">

            <TextBlock Text="CONFIGURACIÓN DE BINGO"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,25"/>

            <TextBlock Text="Premio Cartón Lleno:"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Bold"/>

            <TextBox x:Name="TxtPremio"
                     Height="38"
                     FontSize="16"
                     Margin="0,8,0,20"/>

            <TextBlock Text="Jugadas Disponibles"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>

            <ListBox x:Name="LstDisponibles"
                     Height="170"
                     FontSize="17"
                     Background="#1E1E1E"
                     Foreground="White"
                     BorderBrush="#333333"
                     Margin="0,0,0,15"/>

            <Button Content="SELECCIONAR JUGADA"
                    Height="45"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="#238636"
                    Foreground="White"
                    Click="BtnSeleccionar_Click"
                    Margin="0,0,0,20"/>

            <TextBlock Text="Agregar nueva jugada:"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Bold"/>

            <TextBox x:Name="TxtNuevaJugada"
                     Height="38"
                     FontSize="16"
                     Margin="0,8,0,12"/>

            <Button Content="AGREGAR JUGADA"
                    Height="45"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="#1f6feb"
                    Foreground="White"
                    Click="BtnAgregarJugada_Click"
                    Margin="0,0,0,20"/>

            <TextBlock Text="Jugadas Seleccionadas"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>

            <ListBox x:Name="LstSeleccionadas"
                     Height="170"
                     FontSize="17"
                     Background="#1E1E1E"
                     Foreground="White"
                     BorderBrush="#333333"
                     Margin="0,0,0,15"/>

            <Button Content="QUITAR JUGADA"
                    Height="45"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="#c0392b"
                    Foreground="White"
                    Click="BtnQuitar_Click"
                    Margin="0,0,0,25"/>

            <Button Content="INICIAR BINGO"
                    Height="60"
                    FontSize="20"
                    FontWeight="Bold"
                    Background="Green"
                    Foreground="White"
                    Click="BtnIniciar_Click"/>

        </StackPanel>
    </ScrollViewer>
</Window>