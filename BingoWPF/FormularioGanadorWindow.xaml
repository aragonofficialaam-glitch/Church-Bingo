<Window x:Class="BingoWPF.FormularioGanadorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registrar Ganador"
        Width="700"
        Height="650"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#121212">

    <Grid Margin="35">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="55"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="55"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="REGISTRAR GANADOR"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

        <TextBlock x:Name="LblJugada"
                   Grid.Row="1"
                   Text="Jugada:"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#00ffcc"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

        <TextBlock Grid.Row="2"
                   Text="Nombre de la persona:"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="White"
                   VerticalAlignment="Center"/>

        <TextBox x:Name="TxtNombre"
                 Grid.Row="3"
                 Height="42"
                 FontSize="18"
                 VerticalAlignment="Center"/>

        <TextBlock Grid.Row="4"
                   Text="Premio / Qué ganó:"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="White"
                   VerticalAlignment="Center"/>

        <TextBox x:Name="TxtPremio"
                 Grid.Row="5"
                 Height="42"
                 FontSize="18"
                 VerticalAlignment="Top" Margin="0,5,0,0"/>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top" Margin="124,3,0,0">

            <Button Content="GUARDAR"
                    Width="180"
                    Height="55"
                    FontSize="18"
                    FontWeight="Bold"
                    Background="#27ae60"
                    Foreground="White"
                    Margin="10"
                    Click="BtnGuardar_Click"/>

            <Button Content="CANCELAR"
                    Width="180"
                    Height="55"
                    FontSize="18"
                    FontWeight="Bold"
                    Background="#c0392b"
                    Foreground="White"
                    Margin="10"
                    Click="BtnCancelar_Click"/>
        </StackPanel>
    </Grid>
</Window>